<Window x:Class="WinRinglight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinRinglight Overlay" WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent" Topmost="True" ShowInTaskbar="False" Icon="icon.ico">

    <Grid x:Name="MainGrid">
        <Grid.OpacityMask>
            <RadialGradientBrush x:Name="CursorCutoutMask" MappingMode="Absolute">
                <GradientStop x:Name="StopInner" Color="#00000000" Offset="0.0"/>
                <GradientStop x:Name="StopMiddle" Color="#00000000" Offset="0.5"/>
                <GradientStop x:Name="StopOuter" Color="#FFFFFFFF" Offset="1.0"/>
            </RadialGradientBrush>
        </Grid.OpacityMask>
    </Grid>
</Window>