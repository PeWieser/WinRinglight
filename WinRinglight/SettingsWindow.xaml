<Window x:Class="WinRinglight.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinRinglight Settings" Height="350" Width="400"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen" Background="#F0F0F0">

    <StackPanel Margin="20">
        <TextBlock x:Name="LblBrightness" Text="Brightness" FontWeight="Bold" Margin="0,0,0,5"/>
        <Slider x:Name="SliderBrightness" Minimum="0.1" Maximum="1.0" Value="1.0" 
                TickFrequency="0.1" IsSnapToTickEnabled="True" ValueChanged="Slider_ValueChanged"/>

        <TextBlock x:Name="LblThickness" Text="Ringlight Thickness" FontWeight="Bold" Margin="0,20,0,5"/>
        <Slider x:Name="SliderThickness" Minimum="10" Maximum="200" Value="60" 
                ValueChanged="Slider_ValueChanged"/>

        <TextBlock x:Name="LblTemperature" Text="Color Temperature (Warm -> Cold)" FontWeight="Bold" Margin="0,20,0,5"/>
        <Slider x:Name="SliderTemperature" Minimum="2000" Maximum="6500" Value="4500" 
                ValueChanged="Slider_ValueChanged"/>

        <TextBlock Text="Visual Style" FontWeight="Bold" Margin="0,20,0,5"/>
        <ComboBox x:Name="ComboStyle" SelectionChanged="ComboStyle_SelectionChanged">
            <ComboBoxItem Content="Apple Style (Squircle / Rounded)"/>
            <ComboBoxItem Content="Windows Style (Angular)"/>
        </ComboBox>
    </StackPanel>
</Window>