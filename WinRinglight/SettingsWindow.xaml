<Window x:Class="WinRinglight.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinRinglight Settings" Width="450" 
        SizeToContent="Height" ResizeMode="NoResize"
        WindowStyle="ToolWindow" WindowStartupLocation="CenterScreen" 
        Background="#1E1E1E" Foreground="#E0E0E0" Icon="icon.ico">


    <Window.Resources>
        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}" CornerRadius="6,6,0,0" Padding="{TemplateBinding Padding}" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E1E1E"/>
                                <Setter Property="Foreground" Value="#66B2FF"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#66B2FF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="False"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="20"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Height="4" Background="{TemplateBinding Background}" CornerRadius="2" VerticalAlignment="Center" Margin="5,0"/>
                            <Track Grid.Row="1" x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Opacity="0" IsHitTestVisible="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16" Fill="#E0E0E0" Stroke="#1E1E1E" StrokeThickness="2" Cursor="Hand"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Opacity="0" IsHitTestVisible="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <TabControl Margin="0,0,0,0">

            <TabItem x:Name="TabAppearance" Header="Aussehen">
                <StackPanel Margin="0,15,0,0">
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="LblThickness" Text="Ringlight Dicke" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Slider x:Name="SliderThickness" Minimum="10" Maximum="200" Value="60" 
                                    Background="#555" TickFrequency="1" IsSnapToTickEnabled="True"
                                    ValueChanged="Slider_ValueChanged"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="LblTemperature" Text="Farbtemperatur" FontWeight="Bold" Margin="0,0,0,10"/>
                            <CheckBox x:Name="ChkAutoTemp" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,0,0,15"
                                      Checked="ChkAutoTemp_Changed" Unchecked="ChkAutoTemp_Changed">
                                <TextBlock x:Name="LblAutoTemp" Text="Automatisch an Tageszeit anpassen"/>
                            </CheckBox>
                            <Grid>
                                <Border Height="6" CornerRadius="3" Margin="8,0,8,0" VerticalAlignment="Center">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#FFAA32" Offset="0.0"/>
                                            <GradientStop Color="#FFE19E" Offset="0.5"/>
                                            <GradientStop Color="#EBF5FF" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Grid Margin="8,0,8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2000*"/>
                                        <ColumnDefinition Width="2500*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#88000000" BorderThickness="0,0,2,0" HorizontalAlignment="Right" Height="12"/>
                                </Grid>
                                <Slider x:Name="SliderTemperature" Minimum="2000" Maximum="6500" Value="4000" 
                                        Background="Transparent" IsSnapToTickEnabled="False"
                                        ValueChanged="SliderTemperature_ValueChanged"/>
                            </Grid>
                            <Grid Margin="0,5,0,0">
                                <TextBlock x:Name="LblWarm" Text="Warm" HorizontalAlignment="Left" FontSize="11" Foreground="#AAAAAA"/>
                                <Grid Margin="8,0,8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2000*"/>
                                        <ColumnDefinition Width="2500*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="(Neutral)" HorizontalAlignment="Right" FontSize="10" Foreground="#666666" Margin="0,0,-22,0"/>
                                </Grid>
                                <TextBlock x:Name="LblCold" Text="Kalt" HorizontalAlignment="Right" FontSize="11" Foreground="#AAAAAA"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="LblTheme" Text="Visuelles Design" FontWeight="Bold" Margin="0,0,0,10"/>
                            <ComboBox x:Name="ComboStyle" SelectionChanged="ComboStyle_SelectionChanged" 
                                      Background="#3D3D3D" Foreground="White" BorderBrush="#555" Padding="5">
                                <ComboBoxItem Content="Apple Style (Squircle / Rounded)"/>
                                <ComboBoxItem Content="Windows Style (Angular)"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <TabItem x:Name="TabSystem" Header="System">
                <StackPanel Margin="0,15,0,0">

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="LblMonitor" Text="Monitor Selection" FontWeight="Bold" Margin="0,0,0,10"/>

                            <ItemsControl x:Name="MonitorItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource {x:Type ToggleButton}}" 
                              Content="{Binding Number}" 
                              IsChecked="{Binding IsSelected}"
                              Width="40" Height="40" Margin="0,0,10,10"
                              Checked="MonitorBox_Changed" Unchecked="MonitorBox_Changed">
                                            <CheckBox.ToolTip>
                                                <ToolTip Content="{Binding Info}"/>
                                            </CheckBox.ToolTip>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <CheckBox x:Name="ChkSpanAll" Margin="0,10,0,0" Foreground="White" 
                                      Checked="ChkSpanAll_Changed" Unchecked="ChkSpanAll_Changed">
                                <TextBlock x:Name="LblSpanAll" Text="Über alle Monitore spannen"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <CheckBox x:Name="ChkAutostart" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,0,0,15" Checked="ChkAutostart_Changed" Unchecked="ChkAutostart_Changed">
                                <TextBlock x:Name="LblAutostart" Text="Mit Windows starten"/>
                            </CheckBox>

                            <CheckBox x:Name="ChkWebcam" Foreground="#E0E0E0" FontWeight="SemiBold" Checked="ChkWebcam_Changed" Unchecked="ChkWebcam_Changed">
                                <TextBlock x:Name="LblWebcam" Text="Automatisch einschalten, wenn Webcam aktiv ist"/>
                            </CheckBox>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="LblHotkey" Text="Tastenkombination (Ein-/Ausschalten)" FontWeight="Bold" Margin="0,0,0,10"/>

                            <TextBox x:Name="TxtHotkey" Background="#1E1E1E" Foreground="#66B2FF" BorderBrush="#555" 
                                     Padding="8" FontSize="14" FontWeight="Bold" TextAlignment="Center"
                                     IsReadOnly="True" Cursor="Hand"
                                     GotFocus="TxtHotkey_GotFocus" LostFocus="TxtHotkey_LostFocus"
                                     PreviewKeyDown="TxtHotkey_PreviewKeyDown" 
                                     ToolTip="Klicke hier und drücke deine gewünschte Kombination"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="LblAboutTitle" Text="Info über das Programm" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Author:" Foreground="#888" Margin="0,0,10,5"/>
                                <TextBlock Text="Melo" Grid.Column="1" FontWeight="SemiBold" Margin="0,0,0,5"/>

                                <TextBlock Text="Version:" Grid.Row="1" Foreground="#888" Margin="0,0,10,5"/>
                                <TextBlock Text="1.0.0" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5"/>

                                <TextBlock Text="GitHub:" Grid.Row="2" Foreground="#888" Margin="0,0,10,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1">
                                    <Hyperlink NavigateUri="https://github.com/pewieser/WinRinglight" RequestNavigate="LinkGithub_RequestNavigate">
                                        <Run Text="github.com/pewieser/WinRinglight"/>
                                    </Hyperlink>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Hyperlink x:Name="LinkSupport" Click="LinkSupport_Click" TextDecorations="None">
                            <TextBlock x:Name="LblSupport" Text="Unterstütze dieses Projekt" Foreground="#66B2FF" FontWeight="SemiBold"/>
                        </Hyperlink>
                    </TextBlock>

                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Window>